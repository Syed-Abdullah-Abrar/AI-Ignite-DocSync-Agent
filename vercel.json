{
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/chat", "destination": "/index.html" },
    { "source": "/health", "destination": "/api/index.py" },
    { "source": "/chat/message", "destination": "/api/index.py" },
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/whatsapp/webhook", "destination": "/api/index.py" }
  ]
}
